# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real secrets.
# ---------------------------------------------------------------------------

# ── Shared ──────────────────────────────────────────────────────────────────
# A random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use the default SQLite file at db/haystack.db
# DATABASE_URL=sqlite:////home/jlane/the_haystack/db/haystack.db
# DATABASE_URL=postgresql://user:password@localhost/haystack

# ── Flask environment ─────────────────────────────────────────────────────────
# "development" enables DEBUG mode and detailed error pages.
# "production" disables debug and enforces SECRET_KEY from env.
FLASK_ENV=development
